# === Noethrion .gitignore ===

# --- Secrets & Internal ---
*.env
*.env.local
*.env.*.local
.env.production
*.key
*.pem
*.p12
*.pfx
secrets/
internal/
private/
.secrets/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Linux ---
*~
.fuse_hidden*
.directory
.Trash-*

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.venv/
venv/
env/
ENV/
.mypy_cache/
.ruff_cache/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn-integrity
.pnp
.pnp.js

# --- Foundry / Solidity ---
cache/
out/
broadcast/
forge-cache/
artifacts/
typechain/
typechain-types/
coverage/
coverage.json
.deps/

# --- Hardhat (if used) ---
artifacts/
cache_hardhat/

# --- Rust ---
target/
Cargo.lock
**/*.rs.bk

# --- C/C++ / PlatformIO / ESP-IDF ---
.pio/
.pioenvs/
.piolibdeps/
*.o
*.obj
*.elf
*.bin
*.hex
*.map
build/
sdkconfig.old

# --- Logs & Temp ---
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.orig

# --- Docs builds ---
docs/_build/
docs/.docusaurus/
.cache/

# --- Misc ---
.history/
.serverless/
*.pid
*.seed
.eslintcache
.stylelintcache

# Local Claude Code config (skills, agents, settings)
.claude/

# Local MCP runtime artifacts (serena symbolic index, ruvector memory db)
.serena/
ruvector.db
agentdb.rvf
agentdb.rvf.lock

# --- Lifecycle example runtime artifacts (created by tools/run_lifecycle.sh) ---
examples/lifecycle/attester.key.pub
examples/lifecycle/attestation.json
examples/lifecycle/batch.json
